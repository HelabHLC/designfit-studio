{$DESIGNFIT_DOMAIN} {
  encode zstd gzip

  header {
    -Server
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  reverse_proxy designfit:3000 {
    health_uri /api/health
    health_interval 30s
    health_timeout 5s
  }

  log {
    output stdout
    format json
  }
}
